{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["DOM.Iterable", "DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "coolheaded/*": ["./lib/ts/*"],
      "coolheadedCi/*": ["./.github/ci/*"],
      "coolheadedPackageCodeGraph": ["./packages/codeGraph/update.ts"],
      "coolheadedPackageDeno": ["./packages/deno/update.ts"],
      "coolheadedPackageEntire": ["./packages/entire/update.ts"],
      "coolheadedPackageGrokBuild": ["./packages/grokBuild/update.ts"],
      "coolheadedPackageNixfmt": ["./packages/nixfmt/update.ts"],
      "coolheadedPackageOhMyOpenAgent": ["./packages/oh-my-openAgent/update.ts"],
      "coolheadedPackageOxfmt": ["./packages/oxfmt/update.ts"],
      "coolheadedPackagePaseo": ["./packages/paseo/update.ts"],
      "coolheadedPackageQmd": ["./packages/qmd/update.ts"],
      "coolheadedTestSupport/*": ["./tests/support/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "target": "ESNext",
    "types": [],
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    ".generated/deno.d.ts",
    ".github/ci/**/*.ts",
    "packages/*/update.ts",
    "lib/ts/**/*.ts",
    "tests/**/*.ts",
    "tsReset.d.ts"
  ]
}
