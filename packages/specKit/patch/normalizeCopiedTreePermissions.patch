+def ensure_owner_writable(path: Path) -> None:
+    """Make a copied file tree readable and writable by its owner."""
+    items = [path, *path.rglob("*")] if path.is_dir() else [path]
+    for item in items:
+        mode = item.stat().st_mode
+        owner_permissions = 0o700 if item.is_dir() else 0o600
+        item.chmod(mode | owner_permissions)
+
